default_platform(:android)

platform :android do
  desc "Tự động Build APK và đẩy lên Firebase cho Tester"
  lane :distribute_to_qa do

    # 1. Tạo OTA Patch bằng Shorebird (không cần bump version)
    # - 'shorebird patch android' tạo patch trên release đã có
    # - Users tự nhận update mà không cần cài lại APK
    sh("cd ../.. && shorebird patch android")

    # 2. Upload APK lên Firebase App Distribution
    firebase_app_distribution(
      app: "1:664280682142:android:68754f2ce19d627afc358f",
      apk_path: "../build/app/outputs/flutter-apk/app-release.apk",
      testers: "trunghungpq456@gmail.com",
      release_notes: "Bản build tự động từ CI/CD!"
    )
  end
end