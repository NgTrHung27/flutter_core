default_platform(:android)

platform :android do
  desc "Tự động Build APK và đẩy lên Firebase cho Tester"
  lane :distribute_to_qa do

    # 1. Clean build folder trước
    sh("cd ../.. && flutter clean")

    # 2. Get version từ pubspec.yaml
    version = sh("cd ../.. && grep '^version:' pubspec.yaml | awk '{print $2}'").strip

    # 3. Build và đăng ký release với Shorebird
    # shorebird release tạo baseline APK + đăng ký version với Shorebird servers
    # App Android được build bằng shorebird release sẽ có Shorebird runtime
    # → có thể nhận các patch từ Shorebird servers
    # --artifact apk để tạo APK thay vì AAB (mặc định)
    sh("cd ../.. && shorebird release android --artifact apk")

    # 4. Upload APK lên Firebase App Distribution
    firebase_app_distribution(
      app: "1:664280682142:android:830fe892c914d908fc358f",
      apk_path: "../build/app/outputs/flutter-apk/app-release.apk",
      testers: "trunghungpq456@gmail.com",
      release_notes: "Bản build tự động từ CI/CD!",
      debug: true
    )
  end

  desc "Tạo Shorebird patch cho OTA update"
  lane :shorebird_patch do
    sh("cd ../.. && flutter clean")
    sh("cd ../.. && shorebird patch android")
  end
end
