default_platform(:android)

platform :android do
  desc "Build APK va dan len Firebase cho Tester"
  lane :distribute_to_qa do

    # 1. Clean build folder
    sh("cd ../.. && flutter clean")

    # 2. Shorebird: tao release hoac patch tren server
    #
    # Luu y ve Shorebird Code Push:
    #   - "release"  : tao build moi hoan toan, bao gom assets.
    #                  PHAI bump version khi co thay doi assets (PNG/SVG/fonts...).
    #   - "patch"    : chi update Dart code (AOT diff), KHONG include asset changes.
    #                  Neu co asset changes thi patch se fail voi UnpatchableChangeException.
    #
    # Flow:
    #   - Thu release truoc.
    #   - Neu fail vi VERSION DA TON TAI (exit 70) -> dung patch.
    #   - Neu fail vi LY DO KHAC -> raise lai de CI bao loi.
    release_output = ""
    begin
      release_output = sh("cd ../.. && yes | shorebird release android 2>&1")
    rescue => ex
      error_msg = ex.message + release_output.to_s

      if error_msg.include?("existing") || error_msg.include?("bump your version")
        # Version da ton tai tren Shorebird -> thu patch
        UI.message("Version da ton tai, thu shorebird patch...")
        begin
          sh("cd ../.. && yes | shorebird patch android --release-version latest")
        rescue => patch_ex
          patch_err = patch_ex.message.to_s
          if patch_err.include?("asset changes") || patch_err.include?("UnpatchableChange")
            UI.user_error!(
              "PATCH FAILED: App co thay doi assets (images/svgs/fonts).\n" \
              "Shorebird chi patch Dart code, khong patch assets.\n" \
              "=> Hanh dong can thiet: Bump version trong pubspec.yaml roi chay lai."
            )
          else
            raise patch_ex
          end
        end
      else
        raise ex
      end
    end

    # 3. Build APK rieng cho Firebase
    # Dung flutter build apk thay vi shorebird --artifact apk.
    # Day la artifact doc lap, khong phu thuoc vao Shorebird.
    # APK output: build/app/outputs/flutter-apk/app-release.apk
    sh("cd ../.. && flutter build apk --release")

    # 4. Upload APK len Firebase App Distribution
    firebase_app_distribution(
      app: "1:664280682142:android:830fe892c914d908fc358f",
      apk_path: "../build/app/outputs/flutter-apk/app-release.apk",
      testers: "trunghungpq456@gmail.com",
      release_notes: "Ban build tu dong tu CI/CD!",
      debug: true
    )
  end

  desc "Tao Shorebird patch cho OTA update"
  lane :shorebird_patch do
    sh("cd ../.. && flutter clean")
    sh("cd ../.. && yes | shorebird patch android")
  end
end
